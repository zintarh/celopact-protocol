# CeloPact Agent — Environment Variables
# Copy this file to .env and fill in your values before running.

# ── Wallet Configuration ──────────────────────────────────────────────────
# Private key of the agent wallet (hex, with 0x prefix)
AGENT_A_PRIVATE_KEY=0x...
AGENT_B_PRIVATE_KEY=0x...

# Oracle wallet private key — signs quality attestations for immediate release
# In production this is the Phala TEE worker key, not a regular wallet.
ORACLE_PRIVATE_KEY=0x...

# ── Contract Addresses ────────────────────────────────────────────────────
# CeloPactEscrow contract address (set after deployment)
CONTRACT_ADDRESS=0x...

# USDT token address on Celo Alfajores testnet
USDT_ADDRESS=0x874069Fa1Eb16D44d622F2e0Ca25eeA172369bC1

# ERC-8004 Agent Registry address on Celo Alfajores
REGISTRY_ADDRESS=0x...

# ── Network ───────────────────────────────────────────────────────────────
RPC_URL=https://alfajores-forno.celo-testnet.org

# ── Demo Configuration ────────────────────────────────────────────────────
# Number of times to repeat the full escrow lifecycle in demo mode
DEMO_RUNS=10
