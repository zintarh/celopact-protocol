# CeloPact Agent — Environment Variables
# Copy this file to .env and fill in your values before running.

# ── Wallet Configuration ──────────────────────────────────────────────────
AGENT_A_PRIVATE_KEY=0x...
AGENT_B_PRIVATE_KEY=0x...

# Oracle wallet private key — signs quality attestations for immediate release
# In production this is the Phala TEE worker key, not a regular wallet.
ORACLE_PRIVATE_KEY=0x...

# ── Contract Addresses ────────────────────────────────────────────────────
# CeloPactEscrow contract address (set after running forge script Deploy.s.sol)
CONTRACT_ADDRESS=0x...

# ERC8004Adapter address (set after running forge script Deploy.s.sol)
# This is the REGISTRY_ADDRESS because it implements IAgentRegistry
REGISTRY_ADDRESS=0x...

# ── Token Addresses ───────────────────────────────────────────────────────
# USDT on Celo Sepolia (6 decimals)
USDT_ADDRESS=0xd077A400968890Eacc75cdc901F0356c943e4fDb

# ── Network ───────────────────────────────────────────────────────────────
# Celo Sepolia is the active Celo testnet since the L2 migration (March 2025).
# Chain ID: 11142220
RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# ── Demo Configuration ────────────────────────────────────────────────────
DEMO_RUNS=10
