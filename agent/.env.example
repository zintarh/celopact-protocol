# CeloPact Agent — Environment Variables
# Copy to .env and fill in before running.

AGENT_A_PRIVATE_KEY=0x...
AGENT_B_PRIVATE_KEY=0x...
ORACLE_PRIVATE_KEY=0x...

# Set after: forge script script/Deploy.s.sol --rpc-url celosepolia --broadcast
CONTRACT_ADDRESS=0x...
REGISTRY_ADDRESS=0x...   # ERC8004Adapter address

# Token address — demo reads decimals automatically, works with any ERC-20:
#   USDm (18 decimals, from faucet): 0xEF4d55D6dE8e8d73232827Cd1e9b2F2dBb45bC80
#   USDT (6 decimals):               0xd077A400968890Eacc75cdc901F0356c943e4fDb
TOKEN_ADDRESS=0xEF4d55D6dE8e8d73232827Cd1e9b2F2dBb45bC80

# celo-sepolia (testnet) or celo-mainnet — SDK is network-agnostic
NETWORK=celo-sepolia
RPC_URL=https://forno.celo-sepolia.celo-testnet.org
DEMO_RUNS=10
