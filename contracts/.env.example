# CeloPact Contracts — Environment Variables
# Copy to .env and fill in before deploying.

# Deployer wallet private key (hex, with 0x prefix)
DEPLOYER_PRIVATE_KEY=0x...

# Oracle wallet address — signs quality attestations
# In production: Phala TEE worker address
ORACLE_ADDRESS=0x...

# USDT token address on target chain
# Celo Alfajores (cUSD proxy): 0x874069Fa1Eb16D44d622F2e0Ca25eeA172369bC1
USDT_ADDRESS=0x874069Fa1Eb16D44d622F2e0Ca25eeA172369bC1

# ERC-8004 agent registry address (optional — if empty, deploys MockAgentRegistry)
# REGISTRY_ADDRESS=0x...

# Celoscan API key for contract verification (get at https://celoscan.io/myapikey)
CELOSCAN_API_KEY=your_key_here
