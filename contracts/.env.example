# CeloPact Contracts — Environment Variables
# Copy to .env and fill in before deploying.

DEPLOYER_PRIVATE_KEY=0x...

# Oracle wallet address (signs quality attestations; production: Phala TEE worker)
ORACLE_ADDRESS=0x...

# USDT token address on target chain
# Celo Sepolia: 0xd077A400968890Eacc75cdc901F0356c943e4fDb (6 decimals)
# Celo Mainnet: 0x48065fbBE25f71C9282ddf5e1cD6D6A887483D5e (6 decimals)
USDT_ADDRESS=0xd077A400968890Eacc75cdc901F0356c943e4fDb

# Block explorer API keys for contract verification
BLOCKSCOUT_API_KEY=your_blockscout_key   # for Celo Sepolia
CELOSCAN_API_KEY=your_celoscan_key       # for Celo Mainnet
